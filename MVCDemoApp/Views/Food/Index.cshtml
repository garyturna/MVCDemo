@model IEnumerable<DataLibrary.Models.FoodModel>
@{
    ViewData["Title"] = "Food List";
}

<h1>Food Items</h1>

<table class="table table-striped">

    <thead class="thead-dark">
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var food in Model)
        {
            <tr>
                <td>@food.Title.</td>
                <td>@food.Description</td>
                <td>@food.Price.ToString("C2")</td>
            </tr>
        }
    </tbody>
</table>
